<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top Row: Streak and Block Indicators -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Streak Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#1E1B4B"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:orientation="horizontal"
            android:gravity="center">
            <TextView
                android:id="@+id/widget_streak_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/widget_streak_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0 Days"
                android:textColor="#F87171"
                android:textStyle="bold"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal" />

        <!-- Block Dots -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">
            <TextView
                android:id="@+id/widget_dot_b1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="#4B5563"
                android:textSize="18sp"
                android:paddingHorizontal="2dp" />
            <TextView
                android:id="@+id/widget_dot_b2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="#4B5563"
                android:textSize="18sp"
                android:paddingHorizontal="2dp" />
            <TextView
                android:id="@+id/widget_dot_b3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="#4B5563"
                android:textSize="18sp"
                android:paddingHorizontal="2dp" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E1B4B"
        android:layout_marginVertical="10dp"
        android:orientation="horizontal" />

    <!-- Middle Row: Mascot/Mantra Banner -->
    <TextView
        android:id="@+id/widget_motivation_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Block 1 is waiting for you! 📚"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center_vertical" />

    <!-- Bottom Row: Focus Details -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="6dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CURRENT FOCUS"
            android:textColor="#A78BFA"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />
        <TextView
            android:id="@+id/widget_week_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Week 1: Linear Algebra"
            android:textColor="#9CA3AF"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

</LinearLayout>
